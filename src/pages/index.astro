        <script>
          import { animate, inView } from 'framer-motion';
          import Lenis from 'lenis';

          document.addEventListener("DOMContentLoaded", function () {
            // Lenis Smooth Scroll
            const lenis = new Lenis({
              duration: 1.2,
              easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
              orientation: 'vertical',
              gestureOrientation: 'vertical',
              smoothWheel: true,
              wheelMultiplier: 1,
              touchMultiplier: 2,
            });

            function raf(time) {
              lenis.raf(time);
              requestAnimationFrame(raf);
            }

            requestAnimationFrame(raf);

            // Custom Scrollbar Logic
            const scrollbar = document.getElementById('scrollbar-container');
            const thumb = document.getElementById('scrollbar-thumb');
            let scrollTimeout;

            lenis.on('scroll', ({ scroll, limit, progress }) => {
              if (!scrollbar || !thumb) return;
              
              // Show scrollbar
              scrollbar.style.opacity = '1';
              
              // Calculate thumb size and position
              const trackHeight = scrollbar.offsetHeight;
              const viewportHeight = window.innerHeight;
              const contentHeight = limit + viewportHeight;
              
              // Ensure thumb is at least 40px
              const thumbHeight = Math.max((viewportHeight / contentHeight) * trackHeight, 40);
              const thumbY = progress * (trackHeight - thumbHeight);
              
              thumb.style.height = `${thumbHeight}px`;
              thumb.style.transform = `translateY(${thumbY}px)`;
              
              // Hide scrollbar after 1.5s of inactivity
              clearTimeout(scrollTimeout);
              scrollTimeout = setTimeout(() => {
                scrollbar.style.opacity = '0';
              }, 1500);
            });

            // Project Reveal Animation
            const projects = document.querySelectorAll('.project-row');
            projects.forEach((project) => {
              inView(project, () => {
                animate(
                  project,
                  { opacity: 1, y: [40, 0] },
                  { duration: 0.8, ease: [0.215, 0.61, 0.355, 1] }
                );
              });
            });

            // Custom Cursor
            const cursor = document.getElementById('cursor');
            const links = document.querySelectorAll('a, button, .cursor-pointer');

            let mouseX = 0;
            let mouseY = 0;
            let isTicking = false;
            document.addEventListener('mousemove', (e) => {
              mouseX = e.clientX;
              mouseY = e.clientY;
              if (!isTicking) {
                requestAnimationFrame(() => {
                  cursor.style.left = mouseX + 'px';
                  cursor.style.top = mouseY + 'px';
                  isTicking = false;
                });
                isTicking = true;
              }
            });

            links.forEach(link => {
              link.addEventListener('mouseenter', () => {
                if (link.classList.contains('carousel-target')) {
                  cursor.classList.add('carousel-active');
                } else {
                  cursor.classList.add('cursor-hover');
                }
              });
              link.addEventListener('mouseleave', () => {
                cursor.classList.remove('cursor-hover');
                cursor.classList.remove('carousel-active');
              });
            });

            // Modal Logic
            const modal = document.getElementById('contact-modal');
            const openButtons = document.querySelectorAll('.open-contact-modal');
            const closeButton = document.getElementById('close-contact-modal');
            const customCursor = document.getElementById('cursor');

            openButtons.forEach(btn => {
              btn.addEventListener('click', () => {
                modal.showModal();
                document.body.style.overflow = 'hidden';
                if (customCursor) customCursor.style.opacity = '0';
              });
            });

            closeButton.addEventListener('click', () => {
              modal.close();
              document.body.style.overflow = '';
              if (customCursor) customCursor.style.opacity = '1';
            });

            modal.addEventListener('click', (e) => {
              if (e.target === modal) {
                modal.close();
                document.body.style.overflow = '';
                if (customCursor) customCursor.style.opacity = '1';
              }
            });

            const form = document.getElementById("form");
            const result = document.getElementById("result");

            if (result) result.style.display = "none";

            if (form) {
              form.addEventListener("submit", function (e) {
                e.preventDefault();
                const formData = new FormData(form);
                const object = Object.fromEntries(formData);
                const json = JSON.stringify(object);

                // Show loading message
                result.style.display = "block";
                result.classList.remove("text-green-500", "text-red-400");
                result.classList.add("text-indigo-600");
                result.innerHTML = "Sending...";

                fetch("https://api.web3forms.com/submit", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                  },
                  body: json,
                })
                  .then(async (response) => {
                    let json = await response.json();
                    result.classList.remove("text-indigo-600");
                    if (response.status == 200) {
                      result.classList.add("text-green-500");
                      result.innerHTML = "Message sent successfully!";
                      setTimeout(() => {
                        modal.close();
                        document.body.style.overflow = '';
                        form.reset();
                      }, 1500);
                    } else {
                      result.classList.add("text-red-400");
                      result.innerHTML = json.message;
                    }
                  })
                  .catch((error) => {
                    console.log(error);
                    result.classList.remove("text-indigo-600");
                    result.classList.add("text-red-400");
                    result.innerHTML = "Something went wrong. Please try again.";
                  });
              });
            }
          });
        </script>
      </div>
    </div>
  </body>
</html>
</html>
