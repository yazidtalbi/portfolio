---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style is:global>
      .path {
        pointer-events: none;
        stroke-dasharray: 2500;
        animation: dash 12s;
        animation-direction: reverse;
        animation-timing-function: ease-in-out;
        transform: rotate(-90deg);
      }

      @keyframes dash {
        to {
          stroke-dashoffset: 2540;
        }
      }

      .sticky-info {
        height: fit-content;
        padding: var(--padding);
        padding-right: 0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: sticky;
        top: 40px;
        flex-shrink: 0;
      }

      .specialflex {
        display: flex;
      }

      @media (max-width: 1024px) {
        .specialflex {
          display: block;
        }
      }

      .specialinfo {
        max-width: 280px;
        position: unset;
      }

      @media (max-width: 1024px) {
        .specialinfo {
          max-width: none;
          min-width: none;
        }
      }

      .specialmargin {
        position: sticky;
      }

      @media (max-width: 1024px) {
        .specialmargin {
          margin-top: 30px;
          position: unset;
        }
      }

      @keyframes spin-slow {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }

      .animate-spin-slow {
        animation: spin-slow 16s linear infinite;
      }

      .rotate-text {
        display: block;
        transform: rotate(0deg); /* stays upright inside spinning parent */
        white-space: nowrap;
      }

      /* Custom Cursor */
      .custom-cursor {
        width: 12px;
        height: 12px;
        background-color: black;
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transition: transform 0.1s ease-out;
        display: none;
      }

      @media (pointer: fine) {
        .custom-cursor {
          display: block;
        }
        body, a, button, .cursor-pointer {
          cursor: none !important;
        }
      }

      .cursor-hover {
        transform: scale(2.5);
        mix-blend-mode: difference;
        background-color: white;
      }

      /* Lenis Scroll Base */
      html.lenis {
        height: auto;
      }
      .lenis.lenis-smooth {
        scroll-behavior: auto;
      }
      .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
      }
      .lenis.lenis-stopped {
        overflow: hidden;
      }
    </style>
  </head>

  <body
    class="bg-white selection:bg-black selection:text-white"
  >
    <div id="cursor" class="custom-cursor"></div>
    
    <div
      class="relative w-full"
      id="main-content"
    >




        <!-- Main Content Section -->
        <div
          class="mx-auto w-full mb-4 lg:mb-0"
        >
          <Hero client:load />
          <hr class="border-t border-gray-200 w-full" />

          <div class="pt-12 lg:pt-24">
            <div class="px-4 lg:px-16 mx-auto lg:max-w-screen-2xl">


          <div class="flex space-x-3 items-center mb-2 lg:mb-4">
            <img class="h-6" src="./sparkle-y.svg" /><h1
              class="md:block m-0 text-xl lg:text-3xl font-semibold tracking-tight text-gray-700 lg:text-black"
            >
              Selected Projects
            </h1>
            </div>
          </div>

          <div class="w-full divide-y">
            {
              projects.map((project, projectIndex) => (
                <div class="w-full">
                  <div class="px-4 lg:px-16 mx-auto lg:max-w-screen-2xl">
                    <div class="specialflex lg:space-x-7 lg:space-x-reverse lg:place-content-end animate__animated animate__fadeIn">
                  <div class="order-1 lg:order-2 lg:sticky lg:top-12 lg:mt-6 md:mt-0 specialmargin mb-8  lg:shrink-0 sticky-info specialinfo">
                    <h2
                      class={`text-2xl ${project.color} font-semibold tracking-tight mt-4 md:mt-0`}
                    >
                      {project.title}
                    </h2>
                    <p
                      class={`${project.color} opacity-60  mt-0 font-medium tracking-tight`}
                    >
                      {project.date}
                    </p>

                    {/* <div class="mt-4">
                      <button
                        type="button"
                        class="flex items-center gap-2 text-purple-600 bg-white border-2 border-purple-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-bold text-sm px-3 py-1.5 me-2 mb-2 rounded-full cursor-pointer "
                      >
                        <span>Read the Case Study</span>
                        <svg
                          class="h-3 w-3 text-purple-600"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 320 512"
                          fill="currentColor"
                        >
                          <path d="M310.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-192 192c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L242.7 256 73.4 86.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l192 192z" />
                        </svg>
                      </button>
                    </div> */}

                    <p class="text-black mt-4 tracking-normal text-base font-medium leading-6">
                      {project.description}
                    </p>

                    <ul
                      class={`text-gray-500 marker:${project.color} mt-4 tracking-normal text-base font-medium leading-6 list-disc list-outside pl-5 `}
                    >
                      {project.bullets &&
                        project.bullets.map((item) => <li>{item}</li>)}
                    </ul>

                    <p class="text-gray-400 text-sm mt-8 font-medium tracking-tight">
                      <span class="mr-1 text-gray-500">✦</span> Services
                    </p>

                    <div class="flex flex-wrap gap-2 gap-x-1 mt-3 mb-2">
                      {project.purples &&
                        project.purples.map((purple) => (
                          <span class="bg-purple-100 text-purple-800 text-base font-medium px-3 py-1 rounded-full">
                            {purple}
                          </span>
                        ))}
                    </div>
                  </div>

                  <div class="order-2 lg:order-1 w-full mt-8 mb-8 m-0">
                    <ProjectCarousel 
                      client:load 
                      images={project.images} 
                      title={project.title} 
                    />
                  </div>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="px-4 lg:px-16 mx-auto lg:max-w-screen-2xl">

          <div class="py-10 flex flex-col items-center text-center">
            <h1
              class="md:block m-0 text-xl lg:text-3xl font-semibold tracking-tight text-gray-700 lg:text-black"
            >
              Contact
            </h1>
            <p
              class="mb-4 md:mb-8 mt-2 font-normal text-gray-400 md:text-md text-md max-w-xl"
            >
              Let’s talk about how we can craft a user experience <br
                class="hidden md:block"
              />that not only looks great but drives real growth for your
              product.
            </p>

            <section
              class="pb-0 lg:pb-6 w-full max-w-3xl"
              id="contact-form"
            >
              <div
                class="mb-8 m-0 w-full border border-gray-200 p-4 md:p-8 rounded-lg"
              >
                <form
                  class="space-y-8"
                  action="https://api.web3forms.com/submit"
                  method="POST"
                >
                  <div class="flex flex-col md:flex-row md:space-x-4 mt-0">
                    <div class="flex-1">
                      <label
                        for="full-name"
                        class="block mb-2 text-sm font-medium text-gray-900"
                        >Full Name<span class="text-red-500 ml-1">*</span
                        ></label
                      >
                      <input
                        type="text"
                        id="full-name"
                        name="full_name"
                        class="shadow-sm bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5"
                        placeholder="John Doe"
                        required
                      />
                    </div>
                    <div class="flex-1">
                      <label
                        for="email-address"
                        class="block mb-2 text-sm font-medium text-gray-900 mt-4 md:mt-0"
                        >Email<span class="text-red-500 ml-1">*</span></label
                      >
                      <input
                        type="email"
                        id="email-address"
                        name="email"
                        class="shadow-sm bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5"
                        placeholder="example@domain.com"
                        required
                      />
                    </div>
                  </div>

                  <div class="md:col-span-2">
                    <label
                      for="message"
                      class="block mb-2 text-sm font-medium text-gray-900"
                      >About project<span class="text-red-500 ml-1">*</span
                      ></label
                    >
                    <textarea
                      id="message"
                      name="message"
                      rows="6"
                      class="block p-2.5 w-full text-sm text-gray-900 bg-gray-50 rounded-lg shadow-sm border border-gray-300 focus:ring-primary-500 focus:border-primary-500"
                      placeholder="Describe your project..."
                      required></textarea>
                  </div>

                  <!-- Honeypot Spam Protection -->
                  <input
                    type="checkbox"
                    name="botcheck"
                    class="hidden"
                    style="display: none;"
                  />

                  <input
                    type="hidden"
                    name="access_key"
                    value="19ca72e7-4cbd-446d-86ab-c01c19c5e45d"
                    class="invisible"
                  />

                  <div
                    class="block md:flex lg:space-x-4 space-x-0 justify-center items-center"
                  >
                    <div class="">
                      <p
                        class="text-gray-400 text-xs tracking-normal text-center md:text-left mb-4 md:mb-0"
                      >
                        I'll get back to you <br
                          class="hidden md:block"
                        />within 24 hours
                      </p>
                      <div id="result"></div>
                    </div>

                    <button
                      type="submit"
                      class="cursor pointer uppercase text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:ring-4 focus:outline-none focus:ring-blue-300 rounded-full px-5 py-2.5 text-center inline-flex items-center w-full md:w-48 justify-center"
                    >
                      Send a Message
                      <svg
                        class="rtl:rotate-180 w-3.5 h-3.5 ms-2"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 14 10"
                      >
                        <path
                          stroke="currentColor"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M1 5h12m0 0L9 1m4 4L9 9"></path>
                      </svg>
                    </button>
                  </div>
                </form>
              </div>
            </section>
          </div>
        </div>

        <script>
          import Lenis from 'lenis';

          document.addEventListener("DOMContentLoaded", function () {
            // Lenis Smooth Scroll
            const lenis = new Lenis({
              duration: 1.2,
              easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            });

            function raf(time) {
              lenis.raf(time);
              requestAnimationFrame(raf);
            }

            requestAnimationFrame(raf);

            // Custom Cursor
            const cursor = document.getElementById('cursor');
            const links = document.querySelectorAll('a, button, .cursor-pointer');

            document.addEventListener('mousemove', (e) => {
              cursor.style.left = e.clientX + 'px';
              cursor.style.top = e.clientY + 'px';
            });

            links.forEach(link => {
              link.addEventListener('mouseenter', () => cursor.classList.add('cursor-hover'));
              link.addEventListener('mouseleave', () => cursor.classList.remove('cursor-hover'));
            });

            const form = document.getElementById("form");
            const result = document.getElementById("result");

            if (result) result.style.display = "none";

            if (form) {
              form.addEventListener("submit", function (e) {
                e.preventDefault();
                const formData = new FormData(form);
                const object = Object.fromEntries(formData);
                const json = JSON.stringify(object);

                // Show loading message with indigo color
                result.style.display = "block";
                result.classList.remove("text-green-500", "text-red-400");
                result.classList.add("text-indigo-600");
                result.innerHTML = "Please wait...";

                fetch("https://api.web3forms.com/submit", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                  },
                  body: json,
                })
                  .then(async (response) => {
                    let json = await response.json();
                    result.classList.remove("text-indigo-600"); // Remove loading color
                    if (response.status == 200) {
                      result.classList.add("text-green-500"); // Success color
                      result.innerHTML =
                        "Your message was submitted successfully";
                    } else {
                      result.classList.add("text-red-400"); // Error color
                      result.innerHTML = json.message;
                    }
                  })
                  .catch((error) => {
                    console.log(error);
                    result.classList.remove("text-indigo-600");
                    result.classList.add("text-red-400");
                    result.innerHTML =
                      "Your message was not submitted. Please try again.";
                  })
                  .finally(() => {
                    form.reset();
                    setTimeout(() => {
                      result.style.display = "none";
                      result.classList.remove("text-green-500", "text-red-400");
                    }, 3000);
                  });
              });
            }
          });
        </script>
      </div>
    </div>
  </body>
</html>
