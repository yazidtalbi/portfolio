<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style is:global>
      .path {
        pointer-events: none;
        stroke-dasharray: 2500;
        animation: dash 12s;
        animation-direction: reverse;
        animation-timing-function: ease-in-out;
        transform: rotate(-90deg);
      }

      @keyframes dash {
        to {
          stroke-dashoffset: 2540;
        }
      }

      .sticky-info {
        height: fit-content;
        padding: var(--padding);
        padding-right: 0;
        padding-left: 0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: sticky;
        top: 40px;
        flex-shrink: 0;
      }

      .specialflex {
        display: flex;
      }

      @media (max-width: 1024px) {
        .specialflex {
          display: block;
        }
      }

      .specialinfo {
        max-width: 280px;
        position: unset;
      }

      @media (max-width: 1024px) {
        .specialinfo {
          max-width: none;
          min-width: none;
        }
      }

      .specialmargin {
        position: sticky;
      }

      @media (max-width: 1024px) {
        .specialmargin {
          margin-top: 30px;
          position: unset;
        }
      }

      @keyframes spin-slow {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }

      .animate-spin-slow {
        animation: spin-slow 16s linear infinite;
      }

      .rotate-text {
        display: block;
        transform: rotate(0deg); /* stays upright inside spinning parent */
        white-space: nowrap;
      }

      /* Custom Cursor */
      .custom-cursor {
        width: 12px;
        height: 12px;
        background-color: black;
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transition: transform 0.1s ease-out;
        display: none;
      }

      @media (pointer: fine) {
        .custom-cursor {
          display: block;
        }
        body, a, button, .cursor-pointer {
          cursor: none !important;
        }
      }

      /* Dialog Cursor Fix */
      dialog, dialog * {
        cursor: auto !important;
      }

      .cursor-hover {
        transform: scale(2.5);
        mix-blend-mode: difference;
        background-color: white;
      }

      .cursor-chevron {
        position: absolute;
        top: 50%;
        width: 20px;
        height: 20px;
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        pointer-events: none;
        color: black;
      }

      .cursor-chevron.left {
        left: -28px;
        transform: translateY(-50%) translateX(10px);
      }

      .cursor-chevron.right {
        right: -28px;
        transform: translateY(-50%) translateX(-10px);
      }

      .custom-cursor.carousel-active {
        background-color: white;
        mix-blend-mode: difference;
        transform: scale(1.2);
      }

      .custom-cursor.carousel-active .cursor-chevron {
        opacity: 1;
        color: white;
      }

      .custom-cursor.carousel-active .cursor-chevron.left {
        left: -24px;
        transform: translateY(-50%);
      }

      .custom-cursor.carousel-active .cursor-chevron.right {
        right: -24px;
        transform: translateY(-50%);
      }

      /* Lenis Scroll Base */
      html.lenis {
        height: auto;
      }
      .lenis.lenis-smooth {
        scroll-behavior: auto;
      }
      .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
      }
      .lenis.lenis-stopped {
        overflow: hidden;
      }

      /* Hide scrollbars globally */
      html, body {
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE and Edge */
      }
      
      html::-webkit-scrollbar, body::-webkit-scrollbar {
        display: none; /* Chrome, Safari, Opera */
      }

      /* Hide horizontal overflow globally */
      body {
        overflow-x: hidden;
        width: 100%;
      }

      /* Modal Animations */
      dialog[open] {
        animation: modal-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      dialog::backdrop {
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        animation: backdrop-in 0.4s ease;
      }
      @keyframes modal-in {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes backdrop-in {
        from { opacity: 0; }
        to { opacity: 1; }
      }
    </style>
  </head>

