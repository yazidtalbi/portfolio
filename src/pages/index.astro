    images: [
      "./projects/vf/overview.jpg",
      "./projects/vf/22.png",
      "./projects/vf/request.png",
      "./projects/vf/2.png",
      "./projects/vf/4.webp",
      "./projects/vf/dashboard1.webp",
      "./projects/vf/dashboard2.webp",
    ],
    title: "VisitFootball",
    date: "2024",
    purples: [
      "Redesign",
      "Web Design",
      "Wireframes",
      "Dashboard Design",
      "Design System",
      "Social Media Assets",
    ],
    description:
      "VisitFootball's platform was redesigned to connect a global network of football fans with exclusive experiences across Europe.",
    bullets: [
      "Connect a global network of football fans",
      "Offer exclusive experiences across Europe",
      "Streamline the purchase flow for tickets and events",
    ],
  },
  {
    color: "text-yellow-700",
    images: [
      "./projects/selenitis/2.jpg",
      "./projects/selenitis/3.jpg",
      "./projects/selenitis/1.jpg",
    ],
    title: "Selenitis",
    date: "2023",
    purples: ["Branding", "Social Media Assets"],
    description:
      "Selenitis is a Moroccan luxury brand crafting lampshades and pendant lights, inspired by the serene mineral purity of selenite.",
  },
  {
    color: "text-lime-500",
    images: [
      "./projects/pvenergy/1.png",
      "./projects/pvenergy/2.png",
      "./projects/pvenergy/3.png",
    ],
    title: "PVEnergy",
    date: "2022",
    purples: ["Branding", "Landing Page Design"],
    description:
      "PVEnergy was a Belgian provider specializing in solar panels and green energy solutions.",
  },
  {
    color: "text-red-500",
    images: ["./projects/knockout/knockout-social.jpg"],
